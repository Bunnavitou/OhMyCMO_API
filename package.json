{
  "name": "ohmycmo-api",
  "version": "1.0.0",
  "description": "Express + Prisma + PostgreSQL backend for OhMyCMO",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "dev": "cross-env NODE_ENV=development nodemon src/index.js",
    "start": "cross-env NODE_ENV=production node src/index.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "cross-env NODE_ENV=development dotenv -e .env.development -- prisma migrate dev",
    "prisma:migrate:deploy": "cross-env NODE_ENV=production dotenv -e .env.production -- prisma migrate deploy",
    "prisma:studio:dev": "cross-env NODE_ENV=development dotenv -e .env.development -- prisma studio",
    "prisma:studio:prod": "cross-env NODE_ENV=production dotenv -e .env.production -- prisma studio",
    "db:seed": "cross-env NODE_ENV=development dotenv -e .env.development -- node prisma/seed.js"
  },
  "keywords": [
    "express",
    "prisma",
    "postgresql",
    "jwt",
    "api"
  ],
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "cross-env": "^7.0.3",
    "dotenv": "^16.4.5",
    "dotenv-cli": "^7.4.2",
    "express": "^4.21.2",
    "express-rate-limit": "^7.4.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "nodemon": "^3.1.7",
    "prisma": "^5.22.0"
  }
}
